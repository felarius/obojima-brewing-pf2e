<form class="obojima-brewing">
  <header class="obojima-header">
    <h2>Brewing Cauldron</h2>
    <p>Drag three ingredient items from a character inventory into the slots below.</p>
  </header>

  <section class="obojima-actor-row">
    <label>Selected brewer:</label>
    <strong>{{actorName}}</strong>
  </section>

  <section class="obojima-slots">
    {{#each slots}}
      <div class="obojima-slot" data-slot="{{@index}}">
        <div class="slot-title">Ingredient {{add @index 1}}</div>
        {{#if this}}
          <img src="{{this.img}}" />
          <div class="slot-name">{{this.name}}</div>
          {{#if ../isGM}}
            <div class="slot-values">C {{this.combat}} / U {{this.utility}} / W {{this.whimsy}}</div>
          {{/if}}
          <button type="button" class="clear-slot" data-slot="{{@index}}">Clear</button>
        {{else}}
          <div class="empty-slot">Drop ingredient here</div>
        {{/if}}
      </div>
    {{/each}}
  </section>

  {{#if isGM}}
    <section class="obojima-totals">
      <div><label>Combat</label><strong>{{totals.combat}}</strong></div>
      <div><label>Utility</label><strong>{{totals.utility}}</strong></div>
      <div><label>Whimsy</label><strong>{{totals.whimsy}}</strong></div>
      <div><label>Winner</label><strong>{{winner}}</strong></div>
      <div><label>Winning Total</label><strong>{{resultIndex}}</strong></div>
      <div><label>Product Level</label><strong>{{productLevel}}</strong></div>
      <div><label>Total Range</label><strong>{{productRange}}</strong></div>
      <div><label>Products at Level</label><strong>{{productPoolSize}}</strong></div>
    </section>

    <section class="obojima-preview">
      <label>GM Preview:</label>
      <div>{{preview}}</div>
    </section>
  {{else}}
    <section class="obojima-preview">
      <label>Preview:</label>
      <div>Ingredient values and predicted results are hidden from players.</div>
    </section>
  {{/if}}

  <footer class="obojima-actions">
    <button type="button" class="roll-brew"><i class="fas fa-dice-d20"></i> Roll Crafting & Brew</button>
    <button type="button" class="reset-brew"><i class="fas fa-undo"></i> Reset</button>
  </footer>
</form>
